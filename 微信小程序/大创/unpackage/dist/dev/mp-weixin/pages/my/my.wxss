.user-header.data-v-2f1ef635 {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #c92127 0%, #e74c3c 100%);
  border-radius: 0 0 32rpx 32rpx;
  margin-bottom: 32rpx;
}
.user-header .user-avatar.data-v-2f1ef635 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-sizing: border-box;
}
.user-header .user-info.data-v-2f1ef635 {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.user-header .user-info .user-name.data-v-2f1ef635 {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.user-header .user-info .user-type.data-v-2f1ef635 {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
.user-header .user-action .logout-btn.data-v-2f1ef635, .user-header .user-action .login-btn.data-v-2f1ef635 {
  padding: 16rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}
.banner.data-v-2f1ef635 {
  display: flex;
  align-items: center;
  height: 120rpx;
  margin: 0 32rpx 32rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 24rpx;
  padding: 0 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}
.banner image.data-v-2f1ef635 {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
}
.banner .banner-text.data-v-2f1ef635 {
  font-size: 32rpx;
  font-weight: 600;
  color: #c92127;
}
.menu-list.data-v-2f1ef635 {
  padding: 0 32rpx;
}
.menu-list .menu-item.data-v-2f1ef635 {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
