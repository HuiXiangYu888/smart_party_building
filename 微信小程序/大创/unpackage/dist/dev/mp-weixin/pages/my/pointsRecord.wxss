.container.data-v-0f2662e9 {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}
.page-title.data-v-0f2662e9 {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
  position: relative;
  display: inline-block;
  left: 50%;
  transform: translateX(-50%);
}
.page-title.data-v-0f2662e9::after {
  content: "";
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #e74c3c;
  border-radius: 4rpx;
}
.total-stats.data-v-0f2662e9 {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(231, 76, 60, 0.3);
  position: relative;
  overflow: hidden;
}
.total-stats.data-v-0f2662e9::before {
  content: "";
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}
.stats-item.data-v-0f2662e9 {
  text-align: center;
  position: relative;
  z-index: 1;
}
.stats-label.data-v-0f2662e9 {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
}
.stats-value.data-v-0f2662e9 {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}
.points-list.data-v-0f2662e9 {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.list-header.data-v-0f2662e9 {
  display: flex;
  background: #fff5f5;
  padding: 24rpx 20rpx;
  border-bottom: 2rpx solid #ffe8e8;
}
.header-item.data-v-0f2662e9 {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: #e74c3c;
  text-align: center;
}
.header-item.data-v-0f2662e9:first-child {
  text-align: left;
  padding-left: 10rpx;
  flex: 2;
}
.header-item.data-v-0f2662e9:last-child {
  text-align: right;
  padding-right: 10rpx;
  flex: 1.5;
}
.list-body.data-v-0f2662e9 {
  min-height: 200rpx;
}
.points-item.data-v-0f2662e9 {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}
.points-item.data-v-0f2662e9:active {
  background-color: #fafafa;
}
.points-item.data-v-0f2662e9:last-child {
  border-bottom: none;
}
.source.data-v-0f2662e9 {
  flex: 2;
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
  font-weight: 500;
  padding-left: 10rpx;
}
.points.data-v-0f2662e9 {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}
.points.positive.data-v-0f2662e9 {
  color: #e74c3c;
}
