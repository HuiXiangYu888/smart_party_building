<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.server.mapper.TaskEvaluationMapper">

    <resultMap id="BaseResultMap" type="com.example.pojo.entity.TaskEvaluation">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="task_id" property="taskId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="rating" property="rating" jdbcType="INTEGER"/>
        <result column="comment" property="comment" jdbcType="LONGVARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.pojo.entity.TaskEvaluation" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO task_evaluations(task_id,user_id,rating,comment)
        VALUES(#{taskId},#{userId},#{rating},#{comment})
    </insert>

    <select id="selectByTaskId" parameterType="long" resultMap="BaseResultMap">
        SELECT id,task_id,user_id,rating,comment,created_at FROM task_evaluations WHERE task_id = #{taskId} ORDER BY created_at DESC
    </select>

</mapper>


