<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.server.mapper.MemberUpdateRequestMapper">

    <resultMap id="BaseResultMap" type="com.example.pojo.entity.MemberUpdateRequest">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="member_id" property="memberId" jdbcType="BIGINT"/>
        <result column="fields_json" property="fieldsJson" jdbcType="LONGVARCHAR"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="reviewer_id" property="reviewerId" jdbcType="BIGINT"/>
        <result column="remark" property="remark" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="reviewed_at" property="reviewedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.pojo.entity.MemberUpdateRequest" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO member_update_requests (member_id, fields_json, status, created_at)
        VALUES (#{memberId}, #{fieldsJson}, #{status}, NOW())
    </insert>

    <update id="update" parameterType="com.example.pojo.entity.MemberUpdateRequest">
        UPDATE member_update_requests
        <set>
            <if test="fieldsJson != null">fields_json = #{fieldsJson},</if>
            <if test="status != null">status = #{status},</if>
            <if test="reviewerId != null">reviewer_id = #{reviewerId},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="reviewedAt != null">reviewed_at = #{reviewedAt},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectPendingByMemberId" parameterType="long" resultMap="BaseResultMap">
        SELECT * FROM member_update_requests
        WHERE member_id = #{memberId} AND status = 'PENDING'
        ORDER BY id DESC
        LIMIT 1
    </select>

    <select id="selectById" parameterType="long" resultMap="BaseResultMap">
        SELECT * FROM member_update_requests WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM member_update_requests
        <where>
            <if test="status != null and status != ''">
                status = #{status}
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>

