<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.server.mapper.TaskAssignmentMapper">

    <resultMap id="BaseResultMap" type="com.example.pojo.entity.TaskAssignment">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="task_id" property="taskId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="assigned_at" property="assignedAt" jdbcType="TIMESTAMP"/>
        <result column="completed_at" property="completedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.pojo.entity.TaskAssignment" useGeneratedKeys="true" keyProperty="id">
        INSERT IGNORE INTO task_assignments(task_id,user_id,status,assigned_at,completed_at)
        VALUES(#{taskId},#{userId},#{status},#{assignedAt},#{completedAt})
    </insert>

    <update id="updateStatus">
        UPDATE task_assignments SET status = #{status}
        <if test="status == 'COMPLETED'">, completed_at = CURRENT_TIMESTAMP</if>
        WHERE id = #{id}
    </update>

    <select id="selectByTaskId" parameterType="long" resultMap="BaseResultMap">
        SELECT id,task_id,user_id,status,assigned_at,completed_at FROM task_assignments WHERE task_id = #{taskId}
    </select>

    <select id="countByTaskId" parameterType="long" resultType="int">
        SELECT COUNT(*) FROM task_assignments WHERE task_id = #{taskId}
    </select>

    <select id="selectParticipantsByTaskId" parameterType="long" resultType="map">
        SELECT m.username AS name, m.student_id AS studentId, m.mobile AS mobile, a.assigned_at
        FROM task_assignments a
        INNER JOIN members m ON m.id = a.user_id
        WHERE a.task_id = #{taskId}
        ORDER BY a.assigned_at DESC
    </select>

    <delete id="deleteByTaskId" parameterType="long">
        DELETE FROM task_assignments WHERE task_id = #{taskId}
    </delete>

    <delete id="deleteByTaskIdAndUserId">
        DELETE FROM task_assignments WHERE task_id = #{taskId} AND user_id = #{userId}
    </delete>

    <select id="selectTasksByUserId" parameterType="long" resultType="map">
        SELECT 
            t.id,
            t.title,
            t.description,
            t.due_date,
            t.status,
            t.points,
            t.branch_id,
            t.created_by,
            t.created_at,
            a.status AS assignment_status,
            a.assigned_at,
            a.completed_at
        FROM tasks t
        INNER JOIN task_assignments a ON a.task_id = t.id
        WHERE a.user_id = #{userId}
        ORDER BY t.created_at DESC
    </select>

</mapper>


