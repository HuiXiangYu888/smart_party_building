<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.server.mapper.StudyResourceMapper">

    <resultMap id="BaseResultMap" type="com.example.pojo.entity.StudyResource">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="title" property="title" jdbcType="VARCHAR"/>
        <result column="type" property="type" jdbcType="VARCHAR"/>
        <result column="url" property="url" jdbcType="VARCHAR"/>
        <result column="cover_url" property="coverUrl" jdbcType="VARCHAR"/>
        <result column="created_by" property="createdBy" jdbcType="BIGINT"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Columns">id,title,type,url,cover_url,created_by,created_at</sql>

    <insert id="insert" parameterType="com.example.pojo.entity.StudyResource" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO study_resources(title,type,url,cover_url,created_by,created_at)
        VALUES(#{title},#{type},#{url},#{coverUrl},#{createdBy},NOW())
    </insert>

    <delete id="deleteById" parameterType="long">
        DELETE FROM study_resources WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Columns"/>
        FROM study_resources WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Columns"/>
        FROM study_resources
        <where>
            <if test="type != null and type != ''">
                type = #{type}
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <delete id="deleteAll">
        DELETE FROM study_resources
    </delete>

</mapper>


